/** app.wxss - 基于 WeUI 风格 **/

page {
  --weui-BG-0: #ededed;
  --weui-BG-1: #f7f7f7;
  --weui-BG-2: #fff;
  --weui-BG-3: #f7f7f7;
  --weui-FG-0: rgba(0, 0, 0, 0.9);
  --weui-FG-HALF: rgba(0, 0, 0, 0.9);
  --weui-FG-1: rgba(0, 0, 0, 0.5);
  --weui-FG-2: rgba(0, 0, 0, 0.3);
  --weui-FG-3: rgba(0, 0, 0, 0.1);
  --weui-RED: #fa5151;
  --weui-ORANGE: #fa9d3b;
  --weui-YELLOW: #ffc300;
  --weui-GREEN: #07c160;
  --weui-LIGHTGREEN: #91d300;
  --weui-BRAND: #07c160;
  --weui-BLUE: #10aeff;
  --weui-INDIGO: #1485ee;
  --weui-PURPLE: #6467f0;
  --weui-LINK: #576b95;
  --weui-TAG-TEXT-ORANGE: #fa9d3b;
  --weui-TAG-BACKGROUND-ORANGE: rgba(250, 157, 59, 0.1);
  --weui-TAG-TEXT-GREEN: #07c160;
  --weui-TAG-BACKGROUND-GREEN: rgba(7, 193, 96, 0.1);
  --weui-TAG-TEXT-BLUE: #10aeff;
  --weui-TAG-BACKGROUND-BLUE: rgba(16, 174, 255, 0.1);
  --weui-TAG-TEXT-BLACK: rgba(0, 0, 0, 0.5);
  --weui-TAG-BACKGROUND-BLACK: rgba(0, 0, 0, 0.05);

  background-color: var(--weui-BG-0);
  font-family: -apple-system-font, "Helvetica Neue", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  font-size: 16px;
  line-height: 1.4;
  color: var(--weui-FG-0);
}

/* ========== 布局 ========== */
.container {
  min-height: 100vh;
  padding: 0 16px;
  box-sizing: border-box;
}

.page-body {
  padding-bottom: 80px;
}

.weui-panel {
  background: var(--weui-BG-2);
  border-radius: 8px;
  margin: 12px 0;
  overflow: hidden;
}

.weui-panel__hd {
  padding: 16px;
  font-size: 14px;
  color: var(--weui-FG-1);
  border-bottom: 1rpx solid var(--weui-FG-3);
}

.weui-panel__bd {
  /* content area */
}

.weui-panel__ft {
  padding: 12px 16px;
  text-align: center;
  border-top: 1rpx solid var(--weui-FG-3);
}

/* ========== Cell 列表项 ========== */
.weui-cell {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: var(--weui-BG-2);
  position: relative;
}

.weui-cell + .weui-cell::before {
  content: " ";
  position: absolute;
  left: 16px;
  top: 0;
  right: 0;
  height: 1px;
  border-top: 1rpx solid var(--weui-FG-3);
  color: var(--weui-FG-3);
  transform-origin: 0 0;
  transform: scaleY(0.5);
}

.weui-cell_access {
  padding-right: 30px;
}

.weui-cell_access::after {
  content: " ";
  display: inline-block;
  height: 6px;
  width: 6px;
  border-width: 2px 2px 0 0;
  border-color: var(--weui-FG-2);
  border-style: solid;
  transform: matrix(0.71, 0.71, -0.71, 0.71, 0, 0);
  position: absolute;
  top: 50%;
  margin-top: -4px;
  right: 16px;
}

.weui-cell__hd {
  margin-right: 12px;
  display: flex;
  align-items: center;
}

.weui-cell__bd {
  flex: 1;
  overflow: hidden;
}

.weui-cell__ft {
  text-align: right;
  color: var(--weui-FG-1);
  display: flex;
  align-items: center;
}

.weui-cell_title {
  font-size: 17px;
  color: var(--weui-FG-0);
}

.weui-cell_desc {
  font-size: 14px;
  color: var(--weui-FG-1);
  margin-top: 4px;
}

.weui-cell_icon {
  width: 24px;
  height: 24px;
  font-size: 22px;
  line-height: 24px;
  text-align: center;
}

/* ========== 按钮 ========== */
.weui-btn {
  display: inline-block;
  padding: 12px 24px;
  font-size: 17px;
  font-weight: 500;
  text-align: center;
  border-radius: 8px;
  border: none;
  background: var(--weui-BG-1);
  color: var(--weui-FG-0);
  line-height: 1.4;
  position: relative;
  overflow: hidden;
}

.weui-btn::after {
  border-radius: 0;
}

.weui-btn_primary {
  background: var(--weui-BRAND);
  color: #fff;
}

.weui-btn_warn {
  background: var(--weui-RED);
  color: #fff;
}

.weui-btn_default {
  background: var(--weui-BG-1);
  color: var(--weui-FG-0);
}

.weui-btn_plain-primary {
  background: transparent;
  color: var(--weui-BRAND);
  border: 1px solid var(--weui-BRAND);
}

.weui-btn_mini {
  padding: 4px 12px;
  font-size: 14px;
  border-radius: 4px;
}

.weui-btn_block {
  display: block;
  width: 100%;
  margin: 12px 0;
}

.weui-btn[disabled] {
  opacity: 0.5;
}

.weui-btn-group {
  display: flex;
  gap: 8px;
}

.weui-btn-group .weui-btn {
  flex: 1;
}

/* ========== 标签 ========== */
.weui-tag {
  display: inline-block;
  padding: 2px 8px;
  font-size: 12px;
  border-radius: 4px;
  margin-right: 8px;
  vertical-align: middle;
}

.weui-tag_green {
  color: var(--weui-TAG-TEXT-GREEN);
  background: var(--weui-TAG-BACKGROUND-GREEN);
}

.weui-tag_orange {
  color: var(--weui-TAG-TEXT-ORANGE);
  background: var(--weui-TAG-BACKGROUND-ORANGE);
}

.weui-tag_blue {
  color: var(--weui-TAG-TEXT-BLUE);
  background: var(--weui-TAG-BACKGROUND-BLUE);
}

.weui-tag_default {
  color: var(--weui-TAG-TEXT-BLACK);
  background: var(--weui-TAG-BACKGROUND-BLACK);
}

/* ========== 表单 ========== */
.weui-form {
  padding: 16px;
}

.weui-form__item {
  margin-bottom: 16px;
}

.weui-form__label {
  display: block;
  font-size: 14px;
  color: var(--weui-FG-1);
  margin-bottom: 8px;
}

.weui-input {
  width: 100%;
  height: 44px;
  padding: 0 12px;
  font-size: 17px;
  color: var(--weui-FG-0);
  background: var(--weui-BG-2);
  border: 1rpx solid var(--weui-FG-3);
  border-radius: 8px;
  box-sizing: border-box;
}

.weui-textarea {
  width: 100%;
  min-height: 80px;
  padding: 12px;
  font-size: 17px;
  color: var(--weui-FG-0);
  background: var(--weui-BG-2);
  border: 1rpx solid var(--weui-FG-3);
  border-radius: 8px;
  box-sizing: border-box;
}

.weui-picker {
  width: 100%;
  height: 44px;
  line-height: 44px;
  padding: 0 12px;
  font-size: 17px;
  color: var(--weui-FG-0);
  background: var(--weui-BG-2);
  border: 1rpx solid var(--weui-FG-3);
  border-radius: 8px;
  box-sizing: border-box;
}

.weui-picker_placeholder {
  color: var(--weui-FG-2);
}

/* ========== 文本 ========== */
.weui-text_title {
  font-size: 17px;
  font-weight: 500;
  color: var(--weui-FG-0);
}

.weui-text_desc {
  font-size: 14px;
  color: var(--weui-FG-1);
}

.weui-text_tips {
  font-size: 12px;
  color: var(--weui-FG-2);
}

.weui-text_green { color: var(--weui-BRAND); }
.weui-text_red { color: var(--weui-RED); }
.weui-text_orange { color: var(--weui-ORANGE); }
.weui-text_blue { color: var(--weui-BLUE); }
.weui-text_link { color: var(--weui-LINK); }

/* ========== 金额显示 ========== */
.weui-amount {
  font-size: 28px;
  font-weight: 600;
  font-family: "WeChat Sans SS", "Helvetica Neue", "PingFang SC", sans-serif;
}

.weui-amount_income { color: var(--weui-BRAND); }
.weui-amount_expense { color: var(--weui-RED); }

.weui-amount_small {
  font-size: 20px;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.weui-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 0;
}

.weui-empty__icon {
  font-size: 64px;
  color: var(--weui-FG-3);
  margin-bottom: 16px;
}

.weui-empty__text {
  font-size: 14px;
  color: var(--weui-FG-1);
}

/* ========== 底部操作栏 ========== */
.weui-bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  background: var(--weui-BG-2);
  border-top: 1rpx solid var(--weui-FG-3);
  z-index: 100;
}

/* ========== 弹窗 ========== */
.weui-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
}

.weui-dialog {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--weui-BG-2);
  border-radius: 12px;
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
  z-index: 201;
}

.weui-dialog__hd {
  padding: 24px 24px 0;
  text-align: center;
}

.weui-dialog__title {
  font-size: 17px;
  font-weight: 500;
  color: var(--weui-FG-0);
}

.weui-dialog__bd {
  padding: 24px;
  font-size: 15px;
  color: var(--weui-FG-1);
}

.weui-dialog__ft {
  display: flex;
  border-top: 1rpx solid var(--weui-FG-3);
}

.weui-dialog__btn {
  flex: 1;
  height: 48px;
  line-height: 48px;
  text-align: center;
  font-size: 17px;
  color: var(--weui-FG-0);
}

.weui-dialog__btn + .weui-dialog__btn {
  border-left: 1rpx solid var(--weui-FG-3);
}

.weui-dialog__btn_primary {
  color: var(--weui-LINK);
  font-weight: 500;
}

/* ========== 筛选栏 ========== */
.weui-filter-bar {
  display: flex;
  align-items: center;
  padding: 8px 16px;
  background: var(--weui-BG-2);
  border-bottom: 1rpx solid var(--weui-FG-3);
  margin: 0 -16px;
}

.weui-filter-bar .weui-cell {
  padding: 0;
  background: transparent;
}

.weui-filter-bar .weui-cell::before {
  display: none;
}

/* ========== 统计卡片 ========== */
.weui-stat-card {
  background: var(--weui-BG-2);
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 12px;
}

.weui-stat-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
  padding: 12px 0;
}

.weui-stat-item__label {
  font-size: 12px;
  color: var(--weui-FG-1);
  margin-bottom: 4px;
}

.weui-stat-item__value {
  font-size: 24px;
  font-weight: 600;
  font-family: "WeChat Sans SS", "Helvetica Neue", "PingFang SC", sans-serif;
}

/* ========== 分割线 ========== */
.weui-divider {
  height: 1px;
  background: var(--weui-FG-3);
  margin: 16px 0;
  transform: scaleY(0.5);
}

/* ========== 加载更多 ========== */
.weui-loadmore {
  text-align: center;
  padding: 16px;
  font-size: 14px;
  color: var(--weui-FG-1);
}

.weui-loadmore__tips {
  display: inline-block;
  vertical-align: middle;
}

.weui-loadmore_line {
  border-top: 1rpx solid var(--weui-FG-3);
  margin: 0 16px;
}

.weui-loadmore_line .weui-loadmore__tips {
  position: relative;
  top: -10px;
  padding: 0 12px;
  background: var(--weui-BG-0);
}

/* ========== 工具类 ========== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  display: flex;
  flex-wrap: wrap;
}

.flex-1 { flex: 1; }

.text-center { text-align: center; }
.text-right { text-align: right; }

.mt-4 { margin-top: 4px; }
.mt-8 { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mb-8 { margin-bottom: 8px; }
.mb-16 { margin-bottom: 16px; }
.mr-8 { margin-right: 8px; }
.ml-8 { margin-left: 8px; }

.p-12 { padding: 12px; }
.p-16 { padding: 16px; }

/* ========== 兼容旧类名 ========== */
.card { margin-bottom: 12px; }
.tag-main { color: var(--weui-TAG-TEXT-GREEN); background: var(--weui-TAG-BACKGROUND-GREEN); }
.tag-gift { color: var(--weui-TAG-TEXT-ORANGE); background: var(--weui-TAG-BACKGROUND-ORANGE); }
.tag-warehouse { color: var(--weui-TAG-TEXT-BLUE); background: var(--weui-TAG-BACKGROUND-BLUE); }
.tag-active { color: var(--weui-TAG-TEXT-GREEN); background: var(--weui-TAG-BACKGROUND-GREEN); }
.tag-archived { color: var(--weui-TAG-TEXT-BLACK); background: var(--weui-TAG-BACKGROUND-BLACK); }
