<!--pages/book-detail/book-detail.wxml-->
<view class="container page-body">
  <!-- 账本头部 -->
  <view class="weui-panel">
    <view class="weui-cell">
      <view class="weui-cell__bd">
        <view class="weui-cell_title">{{bookName}}</view>
        <view class="weui-cell_desc">
          <text class="weui-tag {{tagClass}}">{{typeLabel}}</text>
        </view>
      </view>
      <view class="weui-cell__ft book-header-actions">
        <text wx:if="{{bookType === 'main'}}" class="weui-text_link" bindtap="goToActivityDetail" style="margin-right:16px">活动</text>
        <text wx:if="{{bookType === 'main'}}" class="weui-text_link" bindtap="goToStatistics">统计</text>
      </view>
    </view>
    
    <!-- 主账本统计摘要 -->
    <view wx:if="{{bookType === 'main'}}" class="weui-stat-row">
      <view class="text-center">
        <view class="weui-stat-item__label">总收入</view>
        <view class="weui-stat-item__value weui-text_green">{{util.formatMoney(summary.totalIncome)}}</view>
      </view>
      <view class="text-center">
        <view class="weui-stat-item__label">总支出</view>
        <view class="weui-stat-item__value weui-text_red">{{util.formatMoney(summary.totalExpense)}}</view>
      </view>
      <view class="text-center">
        <view class="weui-stat-item__label">结余</view>
        <view class="weui-stat-item__value" style="color:{{summary.balance >= 0 ? 'var(--weui-BRAND)' : 'var(--weui-RED)'}}">{{util.formatMoney(summary.balance)}}</view>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="weui-filter-bar">
    <picker range="{{filterOptions}}" value="{{filterIndex}}" bindchange="onFilterChange">
      <view class="weui-cell weui-cell_access">
        <view class="weui-cell__bd">{{filterOptions[filterIndex]}}</view>
      </view>
    </picker>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="weui-loadmore">
    <text class="weui-loadmore__tips">加载中...</text>
  </view>

  <!-- 流水列表 -->
  <block wx:elif="{{records.length > 0}}">
    <view class="weui-panel" wx:for="{{records}}" wx:key="_id">
      <view class="weui-cell">
        <view class="weui-cell__hd">
          <text style="font-size:24px;font-weight:700;color:{{item.type === 'income' ? 'var(--weui-BRAND)' : 'var(--weui-RED)'}}">
            {{item.type === 'income' ? '↓' : '↑'}}
          </text>
        </view>
        <view class="weui-cell__bd">
          <view class="weui-cell_title">{{item.person || item.category || '未知'}}</view>
          <view wx:if="{{item.remark}}" class="weui-cell_desc">{{item.remark}}</view>
        </view>
        <view class="weui-cell__ft">
          <text class="weui-amount_small {{item.type === 'income' ? 'weui-amount_income' : 'weui-amount_expense'}}">
            {{item.type === 'income' ? '+' : '-'}}{{util.formatMoney(item.amount)}}
          </text>
        </view>
      </view>
      
      <!-- 物品明细 -->
      <view wx:if="{{item.items && item.items.length > 0}}" style="padding:4px 16px 4px 56px">
        <block wx:for="{{item.items}}" wx:key="name" wx:for-item="it">
          <text class="weui-text_tips">{{it.name}} x{{it.quantity}}{{it.unit || ''}} </text>
        </block>
      </view>

      <!-- 付款方式 -->
      <view wx:if="{{item.paymentMethod}}" style="padding:4px 16px 4px 56px">
        <text class="weui-tag weui-tag_default">{{item.paymentMethod}}</text>
      </view>

      <view style="padding:8px 16px 12px 56px;display:flex;justify-content:space-between;align-items:center">
        <text class="weui-text_tips">{{item.createdAtStr}}</text>
        <view wx:if="{{canDelete}}" bindtap="deleteRecord" data-id="{{item._id}}">
          <text class="weui-text_red" style="font-size:12px">删除</text>
        </view>
      </view>
    </view>
    
    <!-- 加载更多 -->
    <view wx:if="{{hasMore}}" class="weui-loadmore weui-loadmore_line">
      <text class="weui-loadmore__tips" bindtap="loadMore">加载更多</text>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="weui-empty">
      <view class="weui-empty__icon">📝</view>
      <view class="weui-empty__text">暂无记录</view>
      <view class="weui-empty__text" style="margin-top:4px">点击下方按钮开始记账</view>
    </view>
  </block>

  <!-- 底部操作按钮 -->
  <view class="weui-bottom-bar">
    <view class="weui-btn-group">
      <button wx:if="{{canWrite && bookType === 'main'}}" class="weui-btn weui-btn_primary" bindtap="goToRecord" data-type="income">记收入</button>
      <button wx:if="{{canWrite && bookType === 'main'}}" class="weui-btn weui-btn_warn" bindtap="goToRecord" data-type="expense">记支出</button>
      <button wx:if="{{canWrite && bookType === 'main'}}" class="weui-btn weui-btn_default" bindtap="goToRecord" data-type="stockin">物品入库</button>
      
      <button wx:if="{{canWrite && bookType === 'gift'}}" class="weui-btn weui-btn_primary" bindtap="goToRecord" data-type="gift">登记收礼</button>
      <button wx:if="{{canWrite && bookType === 'gift'}}" class="weui-btn weui-btn_warn" bindtap="goToSettle">结账</button>
      
      <button wx:if="{{canWrite && bookType === 'warehouse'}}" class="weui-btn weui-btn_primary" bindtap="goToRecord" data-type="stockin">物品入库</button>
      <button wx:if="{{canWrite && bookType === 'warehouse'}}" class="weui-btn weui-btn_default" bindtap="goToRecord" data-type="stockout">物品出库</button>
      <button wx:if="{{canWrite && bookType === 'warehouse'}}" class="weui-btn weui-btn_warn" bindtap="goToSettle">结账</button>
    </view>
  </view>
</view>
