<!--pages/members/members.wxml-->
<view class="container">
  <view class="weui-panel">
    <view class="weui-cell">
      <view class="weui-cell__bd">
        <view class="weui-cell_title">活动成员</view>
      </view>
      <view class="weui-cell__ft">
        <text class="weui-text_desc">{{members.length}} 位成员</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="weui-loadmore">
    <text class="weui-loadmore__tips">加载中...</text>
  </view>

  <!-- 成员列表 -->
  <block wx:elif="{{members.length > 0}}">
    <view class="weui-panel" wx:for="{{members}}" wx:key="userId">
      <view class="weui-cell">
        <view class="weui-cell__hd">
          <image wx:if="{{item.avatarUrl}}" class="avatar" src="{{item.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="avatar avatar-placeholder"></view>
        </view>
        <view class="weui-cell__bd">
          <view class="weui-cell_title">{{item.nickName || '未知用户'}}</view>
          <view class="weui-cell_desc">
            <text class="weui-tag {{item.roleInActivity === 'admin' ? 'weui-tag_green' : (item.roleInActivity === 'editor' ? 'weui-tag_orange' : 'weui-tag_default')}}">
              {{item.roleInActivity === 'admin' ? '主事人' : (item.roleInActivity === 'editor' ? '记账员' : '只读')}}
            </text>
            <text class="weui-text_tips">{{item.bookName || '全部账本'}}</text>
          </view>
        </view>
        <view class="weui-cell__ft" wx:if="{{isAdmin && item.roleInActivity !== 'admin'}}">
          <button class="weui-btn weui-btn_default weui-btn_mini" bindtap="changeRole" data-id="{{item.userId}}" data-role="{{item.roleInActivity}}" style="margin-bottom:4px">修改角色</button>
          <button class="weui-btn weui-btn_warn weui-btn_mini" bindtap="removeMember" data-id="{{item.userId}}">移除</button>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="weui-empty">
      <view class="weui-empty__icon">👥</view>
      <view class="weui-empty__text">暂无成员</view>
    </view>
  </block>

  <!-- 邀请按钮 -->
  <view class="mt-16">
    <button class="weui-btn weui-btn_primary weui-btn_block" bindtap="inviteMember">邀请成员</button>
  </view>

  <!-- 邀请弹窗 -->
  <view class="weui-mask" wx:if="{{showInvite}}" bindtap="hideInviteDialog">
    <view class="weui-dialog" catchtap="stopPropagation">
      <view class="weui-dialog__hd">
        <view class="weui-dialog__title">邀请成员</view>
      </view>
      <view class="weui-dialog__bd">
        <view class="weui-form__item">
          <text class="weui-form__label">角色</text>
          <picker range="{{roleOptions}}" value="{{inviteRoleIndex}}" bindchange="onInviteRoleChange">
            <view class="weui-picker">{{roleOptions[inviteRoleIndex]}}</view>
          </picker>
        </view>
        <view wx:if="{{inviteRoleIndex > 0}}" class="weui-form__item">
          <text class="weui-form__label">可访问账本</text>
          <picker range="{{bookOptions}}" value="{{inviteBookIndex}}" bindchange="onInviteBookChange">
            <view class="weui-picker">{{bookOptions[inviteBookIndex] || '全部账本'}}</view>
          </picker>
        </view>
        <view wx:if="{{inviteQR}}" class="text-center mt-16">
          <image src="{{inviteQR}}" mode="widthFix" style="width:200px;height:200px"></image>
          <view class="weui-text_desc mt-8">请对方使用微信扫码加入</view>
        </view>
      </view>
      <view class="weui-dialog__ft">
        <view wx:if="{{!inviteQR}}" class="weui-dialog__btn" bindtap="hideInviteDialog">取消</view>
        <view wx:if="{{!inviteQR}}" class="weui-dialog__btn weui-dialog__btn_primary" bindtap="generateInviteQR">生成二维码</view>
        <view wx:if="{{inviteQR}}" class="weui-dialog__btn weui-dialog__btn_primary" bindtap="hideInviteDialog">关闭</view>
      </view>
    </view>
  </view>
</view>
