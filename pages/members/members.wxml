<!--pages/members/members.wxml-->
<view class="container">
  <view class="card">
    <text class="card-title">活动成员</text>
    <text class="text-gray" style="font-size:24rpx">{{members.length}} 位成员</text>
  </view>

  <!-- 成员列表 -->
  <view wx:if="{{loading}}">
    <view class="empty-state"><text>加载中...</text></view>
  </view>

  <block wx:elif="{{members.length > 0}}">
    <view class="member-card card" wx:for="{{members}}" wx:key="userId">
      <view class="flex-between">
        <view class="flex-row">
          <image class="member-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="ml-10">
            <text class="text-bold">{{item.nickName || '未知用户'}}</text>
            <view class="mt-10">
              <text class="tag tag-{{item.roleInActivity === 'admin' ? 'main' : (item.roleInActivity === 'editor' ? 'gift' : 'warehouse')}}">
                {{item.roleInActivity === 'admin' ? '主事人' : (item.roleInActivity === 'editor' ? '记账员' : '只读')}}
              </text>
              <text class="text-gray" style="font-size:22rpx">{{item.bookName || '全部账本'}}</text>
            </view>
          </view>
        </view>
        <view wx:if="{{isAdmin && item.roleInActivity !== 'admin'}}">
          <button class="btn-outline" size="mini" bindtap="changeRole" data-id="{{item.userId}}" data-role="{{item.roleInActivity}}">修改角色</button>
          <button class="btn-danger mt-10" size="mini" bindtap="removeMember" data-id="{{item.userId}}">移除</button>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <text>暂无成员</text>
    </view>
  </block>

  <!-- 邀请按钮 -->
  <view class="mt-30">
    <button class="btn-primary" style="width:100%" bindtap="inviteMember">邀请成员</button>
  </view>

  <!-- 邀请弹窗 -->
  <view class="modal-mask" wx:if="{{showInvite}}" catchtap="hideInviteDialog">
    <view class="modal-content text-center" catchtap="stopPropagation">
      <text class="card-title" style="display:block;margin-bottom:30rpx">邀请成员</text>
      
      <view class="form-item text-left">
        <text class="form-label">角色</text>
        <picker range="{{roleOptions}}" value="{{inviteRoleIndex}}" bindchange="onInviteRoleChange">
          <view class="picker">{{roleOptions[inviteRoleIndex]}}</view>
        </picker>
      </view>

      <view class="form-item text-left" wx:if="{{inviteRoleIndex > 0}}">
        <text class="form-label">可访问账本</text>
        <picker range="{{bookOptions}}" value="{{inviteBookIndex}}" bindchange="onInviteBookChange">
          <view class="picker">{{bookOptions[inviteBookIndex] || '全部账本'}}</view>
        </picker>
      </view>

      <view wx:if="{{inviteQR}}" class="mt-20">
        <image src="{{inviteQR}}" mode="widthFix" style="width:400rpx;height:400rpx"></image>
        <text class="text-gray mt-10" style="display:block;font-size:24rpx">请对方使用微信扫码加入</text>
      </view>

      <button wx:if="{{!inviteQR}}" class="btn-primary mt-30" style="width:100%" bindtap="generateInviteQR" loading="{{generating}}">生成邀请二维码</button>
      <button class="btn-outline mt-20" bindtap="hideInviteDialog">关闭</button>
    </view>
  </view>
</view>
