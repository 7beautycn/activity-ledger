<!--pages/settle/settle.wxml-->
<view class="container page-body">
  <!-- 摘要 -->
  <view class="weui-stat-card">
    <view class="weui-panel__hd" style="padding-left:0">结账</view>
    <view wx:if="{{bookType === 'gift'}}">
      <view class="weui-cell" style="padding-left:0;padding-right:0">
        <view class="weui-cell__bd">未结现金</view>
        <view class="weui-cell__ft">
          <text class="weui-amount_small weui-amount_income">{{util.formatMoney(summary.unsettledCash)}}</text>
        </view>
      </view>
      <view class="weui-cell" style="padding-left:0;padding-right:0">
        <view class="weui-cell__bd">已收礼品</view>
        <view class="weui-cell__ft">
          <text class="weui-text_blue" style="font-weight:500">{{summary.totalGiftCount || 0}} 件</text>
        </view>
      </view>
    </view>
    <view wx:if="{{bookType === 'warehouse'}}">
      <view class="weui-cell" style="padding-left:0;padding-right:0">
        <view class="weui-cell__bd">当前库存</view>
        <view class="weui-cell__ft">
          <text class="weui-text_orange" style="font-weight:500">{{summary.totalStock || 0}} 件</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 结账表单 -->
  <view class="weui-panel">
    <view class="weui-panel__bd">
      <block wx:if="{{bookType === 'gift'}}">
        <view class="weui-cell">
          <view class="weui-cell__bd">
            <input class="weui-input" type="digit" placeholder="转交现金金额 *" value="{{settleCash}}" bindinput="onCashInput" />
            <view class="weui-text_tips mt-4">可用现金：{{util.formatMoney(summary.unsettledCash)}}</view>
          </view>
        </view>
      </block>

      <view class="weui-cell">
        <view class="weui-cell__bd" style="display:flex;justify-content:space-between;align-items:center">
          <view class="weui-cell_title">转交物品清单</view>
          <text class="weui-text_link" bindtap="addItem" style="font-size:14px">+ 添加</text>
        </view>
      </view>

      <block wx:for="{{settleItems}}" wx:key="index">
        <view style="background:var(--weui-BG-1);margin:0 16px 12px;padding:16px;border-radius:8px">
          <view class="flex-between" style="margin-bottom:8px">
            <text class="weui-text_desc">物品 {{index + 1}}</text>
            <text class="weui-text_red" bindtap="removeItem" data-index="{{index}}" style="font-size:12px">删除</text>
          </view>
          <input class="weui-input" placeholder="物品名称" value="{{item.name}}" bindinput="onItemInput" data-index="{{index}}" data-field="name" style="margin-bottom:8px" />
          <input class="weui-input" type="number" placeholder="数量" value="{{item.quantity}}" bindinput="onItemInput" data-index="{{index}}" data-field="quantity" />
        </view>
      </block>

      <!-- 从已有中选择 -->
      <block wx:if="{{availableItems.length > 0}}">
        <view class="weui-cell">
          <view class="weui-cell__bd">
            <view class="weui-text_desc">从已有{{bookType === 'gift' ? '礼品' : '库存'}}中选择：</view>
          </view>
        </view>
        <view wx:for="{{availableItems}}" wx:key="name">
          <view class="weui-cell weui-cell_access" bindtap="pickFromAvailable" data-item="{{item}}">
            <view class="weui-cell__bd">{{item.name}}</view>
            <view class="weui-cell__ft">
              <text class="weui-text_desc">x{{item.total}}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 结账单预览 -->
  <view wx:if="{{settleResult}}" class="weui-panel">
    <view class="weui-panel__hd">结账单</view>
    <view class="weui-panel__bd">
      <view class="weui-cell">
        <view class="weui-cell__bd">转交现金</view>
        <view class="weui-cell__ft">
          <text class="weui-amount_small weui-amount_income">{{util.formatMoney(settleResult.cashAmount)}}</text>
        </view>
      </view>
      <view wx:if="{{settleResult.items.length > 0}}" class="weui-cell">
        <view class="weui-cell__bd">
          <view class="weui-cell_title">转交物品</view>
          <block wx:for="{{settleResult.items}}" wx:key="name">
            <view class="weui-text_desc">{{item.name}} x{{item.quantity}}</view>
          </block>
        </view>
      </view>
      <view class="weui-cell">
        <view class="weui-cell__bd">操作时间</view>
        <view class="weui-cell__ft">
          <text class="weui-text_desc">{{settleResult.transferTime || ''}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="p-16">
    <view class="weui-btn-group">
      <button wx:if="{{!settleResult}}" class="weui-btn weui-btn_primary" bindtap="doSettle" loading="{{settling}}">确认结账</button>
      <button wx:if="{{settleResult}}" class="weui-btn weui-btn_default" bindtap="previewSettle">预览结账单</button>
      <button wx:if="{{settleResult}}" class="weui-btn weui-btn_primary" bindtap="exportSettleImage">导出为图片</button>
    </view>
  </view>
</view>
