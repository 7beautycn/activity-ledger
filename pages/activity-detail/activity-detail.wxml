<!--pages/activity-detail/activity-detail.wxml-->
<view class="container">
  <!-- 活动信息 -->
  <view class="card">
    <view class="flex-between">
      <view>
        <text class="card-title">{{activity.name}}</text>
        <view class="flex-row mt-10">
          <text class="tag tag-{{activity.status}}">{{activity.status === 'active' ? '进行中' : '已归档'}}</text>
          <text class="text-gray" style="font-size:24rpx">{{activity.startDate}} ~ {{activity.endDate}}</text>
        </view>
      </view>
      <view wx:if="{{isAdmin && activity.status === 'active'}}">
        <button class="btn-outline" size="mini" bindtap="archiveActivity">归档</button>
      </view>
    </view>
    <text class="text-gray mt-10" style="font-size:24rpx">{{activity.location || '未设置地点'}}</text>
  </view>

  <!-- 账本列表 -->
  <view class="section-title mt-20">账本列表</view>
  
  <view wx:if="{{loading}}">
    <view class="empty-state"><text>加载中...</text></view>
  </view>

  <block wx:elif="{{books.length > 0}}">
    <view class="book-card card" wx:for="{{books}}" wx:key="_id" bindtap="goToBook" data-id="{{item._id}}" data-type="{{item.type}}">
      <view class="flex-between">
        <view class="flex-row">
          <text class="book-icon">{{item.icon}}</text>
          <view class="ml-10">
            <text class="text-bold">{{item.name}}</text>
            <view class="flex-row mt-10">
              <text class="tag {{item.tagClass}}">{{item.typeLabel}}</text>
            </view>
          </view>
        </view>
        <view class="text-right">
          <text class="text-gray" style="font-size:22rpx">负责人</text>
          <view><text style="font-size:24rpx">{{item.ownerName || '未知'}}</text></view>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <text>暂无账本</text>
    </view>
  </block>

  <!-- 成员入口 -->
  <view class="section-title mt-20" wx:if="{{isAdmin}}">成员管理</view>
  <view class="card flex-between" wx:if="{{isAdmin}}" bindtap="goToMembers">
    <text>活动成员 ({{memberCount}}人)</text>
    <text style="color:#1aad19">管理 ></text>
  </view>

  <!-- 主事人操作按钮 -->
  <view class="mt-30" wx:if="{{isAdmin && activity.status === 'active'}}">
    <button class="btn-primary mb-20" style="width:100%" bindtap="showCreateBookDialog">+ 创建子账本</button>
    <button class="btn-outline" style="width:100%" bindtap="goToMembers">邀请成员</button>
  </view>

  <!-- 设置收款码 -->
  <view class="section-title mt-20" wx:if="{{isAdmin}}">活动设置</view>
  <view class="card" wx:if="{{isAdmin}}">
    <view class="form-item">
      <text class="form-label">微信收款码</text>
      <view class="flex-row">
        <image wx:if="{{activity.settings && activity.settings.wxPayQR}}" src="{{activity.settings.wxPayQR}}" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:8rpx" bindtap="previewImage" data-src="{{activity.settings.wxPayQR}}"></image>
        <button wx:else class="btn-outline" size="mini" bindtap="uploadQR" data-type="wxPayQR">上传</button>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">支付宝收款码</text>
      <view class="flex-row">
        <image wx:if="{{activity.settings && activity.settings.alipayQR}}" src="{{activity.settings.alipayQR}}" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:8rpx" bindtap="previewImage" data-src="{{activity.settings.alipayQR}}"></image>
        <button wx:else class="btn-outline" size="mini" bindtap="uploadQR" data-type="alipayQR">上传</button>
      </view>
    </view>
  </view>
</view>

<!-- 创建子账本弹窗 -->
<view class="modal-mask" wx:if="{{showCreateBook}}" catchtap="hideCreateBookDialog">
  <view class="modal-content" catchtap="stopPropagation">
    <text class="card-title" style="display:block;text-align:center;margin-bottom:30rpx">创建子账本</text>
    
    <view class="form-item">
      <text class="form-label">账本类型 *</text>
      <picker range="{{bookTypeOptions}}" value="{{newBookTypeIndex}}" bindchange="onBookTypeChange">
        <view class="picker">{{bookTypeOptions[newBookTypeIndex] || '请选择账本类型'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">账本名称</text>
      <input class="form-input" placeholder="如：收礼记录本" value="{{newBookName}}" bindinput="onBookNameInput" />
    </view>

    <view class="form-item">
      <text class="form-label">负责人 *</text>
      <picker range="{{memberNames}}" value="{{selectedMemberIndex}}" bindchange="onMemberChange">
        <view class="picker {{selectedMemberIndex >= 0 ? '' : 'picker-placeholder'}}">
          {{selectedMemberIndex >= 0 ? memberNames[selectedMemberIndex] : '请选择负责人'}}
        </view>
      </picker>
    </view>

    <view class="flex-row mt-30" style="justify-content:space-around">
      <button class="btn-outline" bindtap="hideCreateBookDialog">取消</button>
      <button class="btn-primary" bindtap="createSubBook" loading="{{creating}}">确认创建</button>
    </view>
  </view>
</view>
