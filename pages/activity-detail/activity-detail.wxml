<!--pages/activity-detail/activity-detail.wxml-->
<view class="container">
  <!-- 活动信息 -->
  <view class="weui-panel">
    <view class="weui-cell">
      <view class="weui-cell__bd">
        <view class="weui-cell_title">{{activity.name}}</view>
        <view class="weui-cell_desc" style="margin-top:6px">
          <text class="weui-tag {{activity.status === 'active' ? 'weui-tag_green' : 'weui-tag_default'}}" style="margin-right:8px">{{activity.status === 'active' ? '进行中' : '已归档'}}</text>
          <text>{{activity.startDate}} ~ {{activity.endDate}}</text>
        </view>
      </view>
      <view class="weui-cell__ft" wx:if="{{isAdmin && activity.status === 'active'}}">
        <button class="weui-btn weui-btn_warn weui-btn_mini" bindtap="archiveActivity">归档</button>
      </view>
    </view>
    <view class="weui-cell" wx:if="{{activity.location}}">
      <view class="weui-cell__bd">
        <view class="weui-text_desc">{{activity.location}}</view>
      </view>
    </view>
  </view>

  <!-- 账本列表 -->
  <view class="weui-panel">
    <view class="weui-panel__hd">账本列表</view>
    <view class="weui-panel__bd">
      <view wx:if="{{loading}}" class="weui-loadmore">
        <text class="weui-loadmore__tips">加载中...</text>
      </view>

      <block wx:elif="{{books.length > 0}}">
        <view class="weui-cell weui-cell_access" wx:for="{{books}}" wx:key="_id" bindtap="goToBook" data-id="{{item._id}}" data-type="{{item.type}}">
          <view class="weui-cell__hd">
            <text style="font-size:28px">{{item.icon}}</text>
          </view>
          <view class="weui-cell__bd">
            <view class="weui-cell_title">{{item.name}}</view>
            <view class="weui-cell_desc">
              <text class="weui-tag {{item.tagClass}}">{{item.typeLabel}}</text>
            </view>
          </view>
          <view class="weui-cell__ft">
            <text class="weui-text_tips">负责人: {{item.ownerName || '未知'}}</text>
          </view>
        </view>
      </block>

      <view wx:else class="weui-empty" style="padding:40px 0">
        <view class="weui-empty__text">暂无账本</view>
      </view>
    </view>
  </view>

  <!-- 成员管理 -->
  <view wx:if="{{isAdmin}}" class="weui-panel">
    <view class="weui-cell weui-cell_access" bindtap="goToMembers">
      <view class="weui-cell__bd">
        <view class="weui-cell_title">活动成员 ({{memberCount}}人)</view>
      </view>
      <view class="weui-cell__ft">管理</view>
    </view>
  </view>

  <!-- 主事人操作 -->
  <view class="mt-16" wx:if="{{isAdmin && activity.status === 'active'}}">
    <view class="weui-btn-group">
      <button class="weui-btn weui-btn_primary" bindtap="showCreateBookDialog">创建子账本</button>
      <button class="weui-btn weui-btn_plain-primary" bindtap="goToMembers">邀请成员</button>
    </view>
  </view>

  <!-- 收款码设置 -->
  <view wx:if="{{isAdmin}}" class="weui-panel mt-16">
    <view class="weui-panel__hd">活动设置</view>
    <view class="weui-panel__bd">
      <view class="weui-cell">
        <view class="weui-cell__bd">
          <view class="weui-cell_title">微信收款码</view>
        </view>
        <view class="weui-cell__ft">
          <image wx:if="{{activity.settings && activity.settings.wxPayQR}}" src="{{activity.settings.wxPayQR}}" mode="aspectFill" style="width:60px;height:60px;border-radius:4px" bindtap="previewImage" data-src="{{activity.settings.wxPayQR}}"></image>
          <button wx:else class="weui-btn weui-btn_default weui-btn_mini" bindtap="uploadQR" data-type="wxPayQR">上传</button>
        </view>
      </view>
      <view class="weui-cell">
        <view class="weui-cell__bd">
          <view class="weui-cell_title">支付宝收款码</view>
        </view>
        <view class="weui-cell__ft">
          <image wx:if="{{activity.settings && activity.settings.alipayQR}}" src="{{activity.settings.alipayQR}}" mode="aspectFill" style="width:60px;height:60px;border-radius:4px" bindtap="previewImage" data-src="{{activity.settings.alipayQR}}"></image>
          <button wx:else class="weui-btn weui-btn_default weui-btn_mini" bindtap="uploadQR" data-type="alipayQR">上传</button>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 创建子账本弹窗 -->
<view class="weui-mask" wx:if="{{showCreateBook}}" bindtap="hideCreateBookDialog">
  <view class="weui-dialog" catchtap="stopPropagation">
    <view class="weui-dialog__hd">
      <view class="weui-dialog__title">创建子账本</view>
    </view>
    <view class="weui-dialog__bd">
      <view class="weui-form__item">
        <text class="weui-form__label">账本名称</text>
        <input class="weui-input" placeholder="如：收礼记录本" value="{{newBookName}}" bindinput="onBookNameInput" />
      </view>
    </view>
    <view class="weui-dialog__ft">
      <view class="weui-dialog__btn" bindtap="hideCreateBookDialog">取消</view>
      <view class="weui-dialog__btn weui-dialog__btn_primary" bindtap="createSubBook">确认创建</view>
    </view>
  </view>
</view>
