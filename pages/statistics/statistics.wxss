/** pages/statistics/statistics.wxss **/
.category-bar {
  padding: 16rpx 0;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: #1aad19;
  border-radius: 4rpx;
  transition: width 0.5s;
}

.item-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.inventory-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
