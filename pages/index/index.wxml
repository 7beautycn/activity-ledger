<!--pages/index/index.wxml-->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="weui-panel">
    <view class="weui-cell">
      <view class="weui-cell__hd">
        <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="weui-cell__bd">
        <view class="weui-cell_title">{{userInfo.nickName || '未登录'}}</view>
        <view class="weui-cell_desc">{{userInfo.role || ''}}</view>
      </view>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="weui-panel" style="padding:0">
    <view style="display:flex">
      <view class="tab-item {{activeTab === 'active' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="active">
        <text>进行中</text>
      </view>
      <view class="tab-item {{activeTab === 'archived' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="archived">
        <text>已归档</text>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="weui-loadmore">
    <text class="weui-loadmore__tips">加载中...</text>
  </view>

  <!-- 活动列表 -->
  <block wx:elif="{{activities.length > 0}}">
    <view class="weui-panel" wx:for="{{activities}}" wx:key="_id">
      <view class="weui-cell weui-cell_access" bindtap="goToActivity" data-id="{{item._id}}">
        <view class="weui-cell__bd">
          <view class="weui-cell_title">{{item.name}}</view>
          <view class="weui-cell_desc" style="margin-top:6px">
            <text class="weui-tag {{item.status === 'active' ? 'weui-tag_green' : 'weui-tag_default'}}" style="margin-right:8px">{{item.status === 'active' ? '进行中' : '已归档'}}</text>
            <text>{{item.startDate}} ~ {{item.endDate}}</text>
          </view>
        </view>
        <view class="weui-cell__ft">
          <text class="weui-text_desc">{{item.location || ''}}</text>
        </view>
      </view>
      <view class="weui-stat-row">
        <view class="text-center">
          <view class="weui-stat-item__label">账本</view>
          <view class="weui-stat-item__value weui-text_green">{{item.bookCount || 0}}</view>
        </view>
        <view class="text-center">
          <view class="weui-stat-item__label">成员</view>
          <view class="weui-stat-item__value" style="color:var(--weui-BLUE)">{{item.memberCount || 0}}</view>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="weui-empty">
      <view class="weui-empty__icon">📋</view>
      <view class="weui-empty__text">暂无活动</view>
      <view class="weui-empty__text" style="margin-top:4px">点击下方按钮创建活动</view>
    </view>
  </block>

  <!-- 底部创建按钮 -->
  <view class="weui-bottom-bar">
    <button class="weui-btn weui-btn_primary weui-btn_block" bindtap="showCreateDialog">+ 创建活动</button>
  </view>
</view>

<!-- 创建活动弹窗 -->
<view class="weui-mask" wx:if="{{showCreate}}" bindtap="hideCreateDialog">
  <view class="weui-dialog" catchtap="stopPropagation">
    <view class="weui-dialog__hd">
      <view class="weui-dialog__title">创建新活动</view>
    </view>
    <view class="weui-dialog__bd">
      <view class="weui-form__item">
        <text class="weui-form__label">活动名称 *</text>
        <input class="weui-input" placeholder="如：小明&小红婚礼" value="{{newActivity.name}}" bindinput="onActivityNameInput" />
      </view>
      
      <view class="weui-form__item">
        <text class="weui-form__label">开始日期 *</text>
        <picker mode="date" value="{{newActivity.startDate}}" bindchange="onStartDateChange">
          <view class="picker-value {{newActivity.startDate ? '' : 'picker-placeholder'}}">
            {{newActivity.startDate || '请选择开始日期'}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="weui-form__item">
        <text class="weui-form__label">结束日期</text>
        <picker mode="date" value="{{newActivity.endDate}}" bindchange="onEndDateChange">
          <view class="picker-value {{newActivity.endDate ? '' : 'picker-placeholder'}}">
            {{newActivity.endDate || '请选择结束日期'}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="weui-form__item">
        <text class="weui-form__label">活动地点</text>
        <input class="weui-input" placeholder="如：花园酒店·宴会厅" value="{{newActivity.location}}" bindinput="onLocationInput" />
      </view>
    </view>
    <view class="weui-dialog__ft">
      <view class="weui-dialog__btn" bindtap="hideCreateDialog">取消</view>
      <view class="weui-dialog__btn weui-dialog__btn_primary" bindtap="createActivity">确认创建</view>
    </view>
  </view>
</view>
