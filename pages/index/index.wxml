<!--pages/index/index.wxml-->
<view class="container">
  <!-- 用户信息头部 -->
  <view class="user-header card">
    <view class="flex-row">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="user-info ml-10">
        <text class="text-bold">{{userInfo.nickName || '未登录'}}</text>
        <text class="text-gray" style="font-size:24rpx">{{userInfo.role || ''}}</text>
      </view>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'active' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="active">
      <text>进行中</text>
    </view>
    <view class="tab-item {{activeTab === 'archived' ? 'tab-active' : ''}}" bindtap="switchTab" data-tab="archived">
      <text>已归档</text>
    </view>
  </view>

  <!-- 活动列表 -->
  <view wx:if="{{loading}}">
    <view class="empty-state">
      <text>加载中...</text>
    </view>
  </view>

  <block wx:elif="{{activities.length > 0}}">
    <view class="activity-card card" wx:for="{{activities}}" wx:key="_id" bindtap="goToActivity" data-id="{{item._id}}">
      <view class="flex-between">
        <view>
          <text class="card-title">{{item.name}}</text>
          <view class="flex-row mt-10">
            <text class="tag tag-{{item.status}}">{{item.status === 'active' ? '进行中' : '已归档'}}</text>
            <text class="text-gray" style="font-size:24rpx">{{item.startDate}} ~ {{item.endDate}}</text>
          </view>
        </view>
        <text class="text-gray">{{item.location || ''}}</text>
      </view>
      <view class="flex-row mt-20" style="justify-content:space-around">
        <view class="text-center">
          <text class="text-gray">账本</text>
          <view class="mt-10 text-bold">{{item.bookCount || 0}}个</view>
        </view>
        <view class="text-center">
          <text class="text-gray">成员</text>
          <view class="mt-10 text-bold">{{item.memberCount || 0}}人</view>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <text>暂无活动</text>
      <text class="mt-10 text-gray" style="font-size:24rpx">点击下方按钮创建活动</text>
    </view>
  </block>

  <!-- 底部创建按钮 -->
  <view class="fixed-bottom">
    <button class="btn-primary" style="width:100%" bindtap="showCreateDialog">+ 创建活动</button>
  </view>
</view>

<!-- 创建活动弹窗 -->
<view class="modal-mask" wx:if="{{showCreate}}" catchtap="hideCreateDialog">
  <view class="modal-content" catchtap="stopPropagation">
    <text class="card-title" style="display:block;text-align:center;margin-bottom:30rpx">创建新活动</text>
    
    <view class="form-item">
      <text class="form-label">活动名称 *</text>
      <input class="form-input" placeholder="如：2026清明公祭" value="{{newActivity.name}}" bindinput="onActivityNameInput" />
    </view>
    
    <view class="form-item">
      <text class="form-label">开始日期 *</text>
      <picker mode="date" value="{{newActivity.startDate}}" bindchange="onStartDateChange">
        <view class="picker {{newActivity.startDate ? '' : 'picker-placeholder'}}">
          {{newActivity.startDate || '请选择开始日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">结束日期</text>
      <picker mode="date" value="{{newActivity.endDate}}" bindchange="onEndDateChange">
        <view class="picker {{newActivity.endDate ? '' : 'picker-placeholder'}}">
          {{newActivity.endDate || '请选择结束日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">活动地点</text>
      <input class="form-input" placeholder="如：祠堂" value="{{newActivity.location}}" bindinput="onLocationInput" />
    </view>

    <view class="flex-row mt-30" style="justify-content:space-around">
      <button class="btn-outline" bindtap="hideCreateDialog">取消</button>
      <button class="btn-primary" bindtap="createActivity" loading="{{creating}}">确认创建</button>
    </view>
  </view>
</view>
