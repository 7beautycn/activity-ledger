/** pages/index/index.wxss **/
.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--weui-BG-1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  color: var(--weui-FG-1);
  position: relative;
}

.tab-item::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 3px;
  border-radius: 2px;
  background: transparent;
}

.tab-active {
  color: var(--weui-BRAND);
  font-weight: 500;
}

.tab-active::after {
  background: var(--weui-BRAND);
}
