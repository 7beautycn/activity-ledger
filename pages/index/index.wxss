/** pages/index/index.wxss **/
.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--weui-BG-1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  color: var(--weui-FG-1);
  position: relative;
}

.tab-item::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 3px;
  border-radius: 2px;
  background: transparent;
}

.tab-active {
  color: var(--weui-BRAND);
  font-weight: 500;
}

.tab-active::after {
  background: var(--weui-BRAND);
}

/* 日期选择器样式 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  min-height: 44px;
  font-size: 16px;
  color: var(--weui-FG-0);
  background: var(--weui-BG-1);
  border-radius: 8px;
}

.picker-placeholder {
  color: var(--weui-FG-2);
}

.picker-arrow {
  font-size: 12px;
  color: var(--weui-FG-2);
}
