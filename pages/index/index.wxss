/** pages/index/index.wxss **/

/* Tab 区域顶部留白 */
.tab-bar {
  margin-top: 16px;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14px 0;
  font-size: 15px;
  color: var(--weui-FG-1);
  position: relative;
}

.tab-item::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 3px;
  border-radius: 2px;
  background: transparent;
}

.tab-active {
  color: var(--weui-BRAND);
  font-weight: 500;
}

.tab-active::after {
  background: var(--weui-BRAND);
}

/* ===== 删除模式工具栏 ===== */
.delete-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #fff;
  border-bottom: 1px solid var(--weui-BG-1);
}

.delete-toolbar__title {
  font-size: 15px;
  color: var(--weui-FG-1);
}

.delete-toolbar__actions {
  display: flex;
  align-items: center;
  gap: 16px;
}

.delete-toolbar__cancel {
  font-size: 14px;
  color: var(--weui-LINK);
}

.delete-toolbar__confirm {
  font-size: 14px;
  color: #fff;
  background: var(--weui-RED);
  padding: 6px 18px;
  border-radius: 6px;
}

.delete-toolbar__confirm.disabled {
  background: var(--weui-BG-2);
  color: var(--weui-FG-3);
}

/* ===== 活动列表项 ===== */
.activity-item {
  display: flex;
  align-items: stretch;
}

.activity-item.delete-mode {
  background: var(--weui-BG-1);
}

/* 删除模式下统一活动项内部元素背景 */
.activity-item.delete-mode .weui-cell,
.activity-item.delete-mode .weui-stat-row {
  background: transparent;
}

/* 复选框 */
.select-box {
  display: flex;
  align-items: center;
  padding-left: 16px;
  flex-shrink: 0;
}

.checkbox {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid var(--weui-FG-3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: transparent;
  box-sizing: border-box;
}

.checkbox.checked {
  border-color: var(--weui-BRAND);
  background: var(--weui-BRAND);
  color: #fff;
}

.activity-body {
  flex: 1;
  min-width: 0;
}

/* 删除提示 */
.delete-hint {
  text-align: center;
  padding: 20px 16px;
  font-size: 13px;
  color: var(--weui-FG-2);
}

/* 日期选择器样式 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 12px;
  min-height: 44px;
  font-size: 16px;
  color: var(--weui-FG-0);
  background: var(--weui-BG-1);
  border-radius: 8px;
}

.picker-placeholder {
  color: var(--weui-FG-2);
}

.picker-arrow {
  font-size: 12px;
  color: var(--weui-FG-2);
}
